# Generated rrweb extension (rebuilt by extensions/replay/build.js)
extensions/replay/rrweb-recorder.js

# Bundle artifacts — regenerated by turbo `bundle:cf` / `bundle:antibot` /
# `bundle:rrweb` tasks whose `inputs:` are tracked in turbo.json. The
# `typecheck` task dependsOn these bundles, so they exist on disk before
# tsc runs. Previously committed and rewritten on every `npm run typecheck`,
# leaving the worktree dirty and silently masking content drift.
src/generated/antibot-detect.ts
src/generated/cf-bridge.ts
src/generated/rrweb-script.ts

