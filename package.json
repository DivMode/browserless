{
  "name": "@browserless.io/browserless",
  "version": "2.39.0",
  "description": "The browserless platform",
  "license": "SSPL",
  "author": "browserless.io",
  "bin": {
    "browserless": "./bin/browserless.js"
  },
  "files": [
    "assets/*",
    "bin/*",
    "build/*",
    "docker/*",
    "extensions/*",
    "external/*",
    "fonts/*",
    "scripts/*",
    "src/*",
    "static/*",
    "CHANGELOG.md",
    "tsconfig.json"
  ],
  "type": "module",
  "main": "./build/exports.js",
  "types": "./src/exports.ts",
  "exports": {
    ".": "./build/exports.js"
  },
  "scripts": {
    "schema:generate": "tsx scripts/generate-cf-snapshot-schema.ts",
    "bundle:rrweb": "bun extensions/replay/build.js",
    "bundle:cf": "bun scripts/bundle-cf-bridge.js",
    "bundle:antibot": "bun scripts/bundle-antibot.js",
    "build": "npm run clean && npm run bundle:rrweb && npm run bundle:cf && npm run bundle:antibot && npm run build:ts && npm run install:adblock && npm run build:schemas && npm run build:devtools && npm run build:openapi",
    "build:dev": "npm run build && npm run build:function && npm run install:debugger",
    "build:devtools": "bun scripts/install-devtools.js",
    "build:function": "bun scripts/build-function.js",
    "build:schemas": "bun scripts/build-schemas.js",
    "build:openapi": "bun scripts/build-open-api.js",
    "build:ts": "tsc",
    "typecheck": "npm run bundle:rrweb && npm run bundle:cf && npm run bundle:antibot && tsc --noEmit",
    "build:tests": "npm run build:ts && npm run build:function && npm run install:debugger",
    "clean": "bun scripts/clean.js",
    "dev": "npm run build:dev && env-cmd -f .env bun build",
    "install:adblock": "bun scripts/install-adblock.js",
    "install:debugger": "bun scripts/install-debugger.js",
    "install:browsers": "bun node_modules/playwright-core/cli.js install chromium firefox webkit msedge",
    "install:dev": "npm run install:browsers && npm run install:debugger",
    "prepack": "npm run build:dev",
    "test": "vitest run",
    "test:unit": "vitest run --project=unit",
    "test:integration": "vitest run --project=integration",
    "coverage": "npm run build:ts && c8 --reporter=text --reporter=html --reporter=lcov cross-env DEBUG=quiet mocha",
    "start": "env-cmd -f .env bun build"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1019.0",
    "@divmode/rrweb": "^0.0.40",
    "@divmode/rrweb-plugin-console-record": "^0.0.40",
    "@hapi/bourne": "^3.0.0",
    "@hapi/hoek": "^11.0.4",
    "@pyroscope/nodejs": "^0.4.10",
    "better-sqlite3": "^11.10.0",
    "debug": "^4.4.1",
    "del": "^8.0.1",
    "effect": "^4.0.0-beta.42",
    "file-type": "^21.3.0",
    "get-port": "^7.1.0",
    "gradient-string": "^3.0.0",
    "http-proxy": "^1.18.1",
    "joi": "^18.0.2",
    "lighthouse": "^13.0.1",
    "micromatch": "^4.0.8",
    "node-cron": "^4.2.1",
    "playwright-1.53": "npm:playwright-core@1.53.2",
    "playwright-1.54": "npm:playwright-core@1.54.2",
    "playwright-1.55": "npm:playwright-core@1.55.1",
    "playwright-1.56": "npm:playwright-core@1.56.1",
    "playwright-1.57": "npm:playwright-core@1.57.0",
    "playwright-core": "1.58.1",
    "prom-client": "^15.1.3",
    "puppeteer-core": "24.37.1",
    "puppeteer-extra": "^3.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "queue": "^7.0.0",
    "systeminformation": "^5.30.7",
    "tar-fs": "^3.1.1"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.4",
    "@commitlint/config-conventional": "^20.4.4",
    "@effect/vitest": "^4.0.0-beta.42",
    "env-cmd": "^11.0.0",
    "fast-check": "^4.6.0",
    "vite": "^8.0.0",
    "vitest": "^4.1.0"
  },
  "optionalDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/chai": "^5.2.3",
    "@types/debug": "^4.1.12",
    "@types/gradient-string": "^1.1.6",
    "@types/http-proxy": "^1.17.17",
    "@types/micromatch": "^4.0.10",
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.2.1",
    "@types/sinon": "^21.0.0",
    "@types/ws": "^8.18.1",
    "assert": "^2.0.0",
    "c8": "^10.1.3",
    "chai": "^6.2.2",
    "cross-env": "^10.1.0",
    "env-cmd": "^11.0.0",
    "esbuild": "^0.27.3",
    "esbuild-plugin-polyfill-node": "^0.3.0",
    "extract-zip": "^2.0.1",
    "gunzip-maybe": "^1.4.2",
    "marked": "^17.0.1",
    "mocha": "^11.7.5",
    "move-file": "^4.1.0",
    "sinon": "^21.0.1",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-json-schema": "^0.65.1"
  },
  "mocha": {
    "extension": [
      "js"
    ],
    "loader": "ts-node/esm",
    "slow": 5000,
    "spec": "build/**/*.spec.js",
    "timeout": 45000
  },
  "engines": {
    "node": ">=24",
    "npm": "^11.7.0"
  },
  "playwrightVersions": {
    "default": "playwright-core",
    "1.58": "playwright-core",
    "1.57": "playwright-1.57",
    "1.56": "playwright-1.56",
    "1.55": "playwright-1.55",
    "1.54": "playwright-1.54"
  }
}
