# Enforce conventional commit messages:
#   feat: add new feature
#   fix(scraper): resolve timeout
#   chore: update dependencies
#
# Valid prefixes: feat, fix, docs, style, refactor, perf, test, build, ci, chore, revert
# Optional scope in parentheses: feat(scraper): ...
# Must have a description after the colon

MSG=$(grep -v '^#' "$1" | head -1)

# Allow empty messages (git will abort anyway) and merge commits
if [ -z "$MSG" ]; then
  exit 0
fi

PATTERN='^(feat|fix|docs|style|refactor|perf|test|build|ci|chore|revert)(\(.+\))?: .+'

if ! echo "$MSG" | grep -qE "$PATTERN"; then
  echo ""
  echo "  Bad commit message: $MSG"
  echo ""
  echo "  Must match: <type>(<scope>): <description>"
  echo ""
  echo "  Types: feat fix docs style refactor perf test build ci chore revert"
  echo "  Examples:"
  echo "    feat: add shadow DOM diagnostics"
  echo "    fix(solver): resolve WS leak race"
  echo "    chore: update dependencies"
  echo ""
  exit 1
fi
